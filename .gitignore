# Dependencias de Composer (se reinstalan con composer install)
**/vendor/

# Lockfiles de los sub-proyectos de ejemplo (no del curso en sí)
08-librerias-clave/composer.lock
04-php-avanzado/ejercicios/proyecto-composer/composer.lock

# Entornos y secretos
.env
*.local

# Sistema
.DS_Store
Thumbs.db

# Editor
.idea/
*.swp

# CodeIgniter 3 (proyectos/crud-codeigniter3/app) — archivos generados en runtime
proyectos/crud-codeigniter3/app/application/logs/*.php
proyectos/crud-codeigniter3/app/application/cache/*
!proyectos/crud-codeigniter3/app/application/cache/index.html
!proyectos/crud-codeigniter3/app/application/cache/.htaccess
