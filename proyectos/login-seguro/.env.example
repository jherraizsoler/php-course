APP_NAME="Login Seguro · PHP Course"

# Usuario demo
DEMO_USER=jorge
# Genera el hash con:  php -r "echo password_hash('tu-pass', PASSWORD_DEFAULT);"
DEMO_PASS_HASH='PON_AQUI_TU_HASH_BCRYPT'

# Secreto TOTP (2FA). Genera uno con google2fa->generateSecretKey()
TOTP_SECRET=CAMBIA_ESTE_SECRETO_BASE32
TOTP_ISSUER="PHP Course"

# Rate limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_LOCK=60
